# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# Models
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=legalmind_docs

# RAG Parameters
CHUNK_SIZE=512
CHUNK_OVERLAP=192
RETRIEVAL_TOP_K=20
HYBRID_ALPHA=0.8

# Evaluation
# gpt-4o is used as the judge model for reliable metric scores.
# For cost-efficient dev testing, switch to gpt-4o-mini (~$0.06 per 20 samples).
RAGAS_JUDGE_MODEL=gpt-4o

# Reranker
RERANKER_MODEL=rank-T5-flan
RERANKER_TOP_N=3
RERANKER_SCORE_THRESHOLD=0.05

# API
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO

# Ollama (optional fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
